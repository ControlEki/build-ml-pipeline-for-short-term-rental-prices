name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: Input CSV file to explore and clean
        type: string

      output_artifact:
        description: Cleaned dataset CSV file
        type: string

      output_type:
        description: Cleaned dataset artifact type
        type: string

      output_description:
        description: Cleaned dataset artifact description 
        type: string

      min_price:
        description: Expected minimum price 
        type: float

      max_price:
        description:  Expected maximum price 
        type: float


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
